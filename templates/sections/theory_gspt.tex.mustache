\subsection{Geometric Singularity and State-Space Topologies}
\label{subsec:gspt_topology}

We model the non-equilibrium transitions of the nocturnal stable boundary layer (SBL) as a constrained vector field on a four-dimensional differentiable manifold with boundary. Let $\mathcal{X}$ denote the state space:
\begin{equation}
\mathcal{X}=\left\{\mathbf{x}=(e,U,V,T_s)^T\in\mathbb{R}_+\times\mathbb{R}\times\mathbb{R}\times\mathbb{R}_+\right\}\subset\mathbb{R}^4
\end{equation}
where $e$ represents the turbulent kinetic energy (TKE) density, $(U,V)$ denote the components of the horizontal velocity vector, and $T_s$ is the land surface skin temperature.

\paragraph{Time-Scale Separation.}
The system exhibits a natural time-scale separation governed by the singular perturbation parameter $\varepsilon$:
\begin{equation}
0<\varepsilon\ll1,\quad \varepsilon\coloneqq\frac{\tau_{\text{turb}}}{\tau_{\text{macro}}}
\end{equation}
Here $\tau_{\text{turb}}$ is the rapid turbulent relaxation timescale, typically $\mathcal{O}(10^1\,\text{s})$, while $\tau_{\text{macro}}$ is the slow synoptic-thermodynamic forcing timescale, typically $\mathcal{O}(10^3\text{--}10^4\,\text{s})$. This partition yields the fast-slow decomposition:
\begin{align}
\varepsilon\dot{e}&=\mathcal{F}(e,U,V,T_s) \\
\dot{\mathbf{y}}&=\mathbf{G}(e,\mathbf{y}),\quad \mathbf{y}\coloneqq(U,V,T_s)^T\in\mathbb{R}^3
\end{align}

\subsection{Critical Manifolds and Algebraic Regularization}

In the singular limit $\varepsilon\to0$, the fast-slow flow is first constrained to the algebraic critical set
\begin{equation}
\mathcal{C}\coloneqq\left\{\mathbf{x}\in\mathcal{X}\ \vert\ \mathcal{F}(e,U,V,T_s)=0\right\}.
\end{equation}
The normally hyperbolic critical manifold used in Fenichel theory is then the subset
\begin{equation}
\mathcal{M}_0\coloneqq\left\{\mathbf{x}\in\mathcal{C}\ \vert\ \partial_e\mathcal{F}(e,U,V,T_s)\neq0\right\}.
\end{equation}

\paragraph{Singular Limit Decomposition.}
Writing the system in slow time $t$ gives
\begin{align}
\varepsilon\dot e &= \mathcal{F}(e,U,V,T_s), \\
\dot{\mathbf y} &= \mathbf G(e,\mathbf y),\qquad \mathbf y=(U,V,T_s)^T.
\end{align}
The reduced problem is obtained on $\mathcal{C}$ by enforcing $\mathcal{F}=0$ and evolving the slow variables tangentially. The layer problem is obtained in fast time $\tau=t/\varepsilon$:
\begin{align}
\frac{de}{d\tau} &= \mathcal{F}(e,U,V,T_s), \\
\frac{d\mathbf y}{d\tau} &= \varepsilon\,\mathbf G(e,\mathbf y),
\end{align}
so at $\varepsilon=0$ the slow variables are frozen parameters in the fast subsystem.

\begin{theorem}[Fenichel-Type Persistence]
Let the vector fields $\mathcal{F}, \mathbf{G} \in C^r(\mathcal{X})$ with $r \ge 2$, and let $\mathcal{K} \subset \mathcal{M}_0$ be a compact, normally hyperbolic, and locally invariant submanifold for the reduced problem. Then for sufficiently small $0 < \varepsilon \ll 1$, there exists a locally invariant slow manifold $\mathcal{M}_\varepsilon$ that is $\mathcal{O}(\varepsilon)$ close to $\mathcal{K}$ in the $C^1$ topology, and the perturbed slow flow on $\mathcal{M}_\varepsilon$ is a regular perturbation of the reduced flow on $\mathcal{K}$.
\end{theorem}

\begin{theorem}[Existence and Stability of the Active Branch]
Let $\Delta \coloneqq \eta\,\gamma\,(U^2+V^2) - K\,G(T_s)$ define the net macro-environmental balance. If the admissibility criterion is satisfied:
\begin{equation}
\Delta \ge \frac{\delta}{l_0}
\end{equation}
then the fast subsystem admits a unique, physically admissible equilibrium $e^* = l_0\Delta - \delta$, which is strictly attracting with normal growth rate $\partial_e\mathcal{F} = -\sqrt{\Delta/l_0} < 0$. Conversely, if $\Delta < \delta/l_0$, no stable, physically admissible turbulent equilibrium exists on the critical set.
\end{theorem}

\paragraph{Remark (Alternative Fast Closures and Fold Topologies).}
The closure formulation developed in this framework produces a clean transversal boundary-crossing termination at $e=0$. Alternative higher-order turbulence closures containing cubic production terms or nonlinear shear saturation can instead satisfy the simultaneous conditions:
\begin{equation}
\mathcal{F} = 0, \qquad \partial_e\mathcal{F} = 0
\end{equation}
inside the interior of the state space. Such formulations lead to genuinely folded critical manifolds, relaxation oscillations, and canard dynamics. These alternative geometries are discussed in Figure~\ref{fig:fold_envelope} solely as a comparative benchmark; they are not generated by the mathematical system analyzed here.

