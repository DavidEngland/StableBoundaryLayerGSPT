Manifest.toml
.DS_Store

bak/*.*

results/**/run_*/
results/**/bifurcation_*/
reports/generated/**
!reports/generated/.gitkeep
!reports/generated/theory/.gitkeep
!reports/generated/mathematics/.gitkeep
!reports/generated/physics/.gitkeep
!reports/generated/diagnostics/.gitkeep
!reports/generated/figures/.gitkeep
!reports/generated/tables/.gitkeep

figures/*.json
figures/*.pdf
figures/*.tex
figures/*.md
figures/*.aux
figures/*.log
tables/*.json
tables/*.tex
tables/*.md

bundle/**

# Generated SCM portfolio compile artifacts
compile_reports.aux
compile_reports.log
compile_reports.out
compile_reports.toc

# Per-case wrapper compile byproducts
results/**/*_report_wrapper.aux
results/**/*_report_wrapper.log
results/**/scm_case_report_wrapper.aux
results/**/scm_case_report_wrapper.log

# ==============================================================================
# Simulation Output Binaries & Data Dumps
# ==============================================================================
# Block all Julia data storage binaries and raw tabular outputs everywhere
*.jld2
*.csv
*.h5

# Block all generated diagnostic figures and run payloads in results/ directories
results/**/*.png
results/**/*.pdf
results/**/*.jld2
results/**/*.csv
results/**/*.json
results/**/plots/

# Keep the directory structure intact if needed, but ignore the contents
!results/**/.gitkeep